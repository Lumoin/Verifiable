<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>verifiable</ToolCommandName>

    <Title>A command line tool for security elements, DIDs and VCs</Title>
    <Description>A command line tool for system security elements, decentralized identifiers and verifiable credentials.</Description>
    <PackageTags>ssi wallet tpm2 trusted-platform-module eidas did self-sovereign-identity verifiable-credentials decentralized-identifiers</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <!-- PublishAot=true drives native AOT compilation when dotnet pack -r <rid>
         is invoked in CI. TrimMode and PublishTrimmed are implied by AOT and
         are not set here to avoid conflicting with Directory.Build.props.
    -->
    <PublishAot>true</PublishAot>
    <RuntimeIdentifiers>linux-x64;linux-arm64;win-x64;win-arm64;osx-x64;osx-arm64;any</RuntimeIdentifiers>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="/" />
    <None Include=".mcp\server.json" Pack="true" PackagePath=".mcp" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ModelContextProtocol" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="System.CommandLine" />
    <PackageReference Include="dotNetRdf" />
    <PackageReference Include="SimpleBase" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Verifiable.Tpm\Verifiable.Tpm.csproj" />
    <ProjectReference Include="..\Verifiable.Core\Verifiable.Core.csproj" />
    <ProjectReference Include="..\Verifiable.Microsoft\Verifiable.Microsoft.csproj" />
    <!--
      This is the composition root: the "consumer that chooses its serialization layer" the
      ValidateProjectReferences target's own restriction is written for (Directory.Packages.props).
      Verifiable.Fido2 stays serialization-agnostic; this CLI/MCP application is where it is paired
      with the CBOR/JSON codec defaults for FIDO2 attestation/assertion verification.
    -->
    <ProjectReference Include="..\Verifiable.Fido2\Verifiable.Fido2.csproj" />
    <ProjectReference Include="..\Verifiable.Cbor\Verifiable.Cbor.csproj" />
    <ProjectReference Include="..\Verifiable.Json\Verifiable.Json.csproj" />
  </ItemGroup>

</Project>