<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>    
    <Title>OAuth and OpenID protocols for Verifiable credentials.</Title>
    <Description>Implementation of OAuth 2.0 extensions and OpenID protocols for verifiable credential ecosystems. Includes OpenID4VCI (credential issuance), OpenID4VP (verifiable presentations), JAR, PAR, dynamic client registration, token exchange and federation support.</Description>
    <PackageTags>OAuth OpenID OpenID4VCI OpenID4VP JAR PAR DPoP VerifiableCredentials Wallet Federation</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Verifiable.Foundation\Verifiable.Foundation.csproj" />
    <ProjectReference Include="..\Verifiable.Core\Verifiable.Core.csproj" />
    <ProjectReference Include="..\Verifiable.JCose\Verifiable.JCose.csproj" />
    <ProjectReference Include="..\Verifiable.Server\Verifiable.Server.csproj" />
  </ItemGroup>

  <!-- System.Net.Http is banned in this library (see BannedSymbols.OAuth.txt):
       Verifiable.OAuth is transport-agnostic, so HTTP delegates take an
       OutboundTransportDelegate the application wires to its HttpClient. Drop
       the SDK's implicit global using so the namespace is not even in scope. -->
  <ItemGroup>
    <Using Remove="System.Net.Http" />
  </ItemGroup>

</Project>
