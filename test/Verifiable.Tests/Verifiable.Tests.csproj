<Project Sdk="MSTest.Sdk">
  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <EnableTrimAnalyzer>false</EnableTrimAnalyzer>
    <EnableAotAnalyzer>false</EnableAotAnalyzer>
    <!--
      CA2007 exists for library code where the caller's SynchronizationContext
      is unknown and a captured context could deadlock. Test runners (MSTest,
      xUnit, NUnit) run on ThreadPool threads with no SynchronizationContext,
      so ConfigureAwait(false) on every test await is functionally a no-op.
      The rule fires on `await using` (synthesised dispose await) which we
      want to use uniformly across IAsyncDisposable test fixtures. Suppressed
      project-wide.
    -->
    <NoWarn>$(NoWarn);CA2007</NoWarn>
    <!--
      Displays error on console in addition to the log file. Note that this feature comes with a performance impact.
      For more information, visit https://learn.microsoft.com/dotnet/core/testing/unit-testing-platform-integration-dotnet-test#show-failure-per-test
      -->
    <TestingPlatformShowTestsFailure>true</TestingPlatformShowTestsFailure>
    <RunSettingsFilePath>$(MSBuildProjectDirectory)\config.runsettings</RunSettingsFilePath>
    <TestingExtensionsProfile>AllMicrosoft</TestingExtensionsProfile>
    <IsTestApplication>true</IsTestApplication>
    <MSTestAnalysisMode>Recommended</MSTestAnalysisMode>
  </PropertyGroup>
 
  <ItemGroup>
    <PackageReference Include="dotNetRdf" />
    <PackageReference Include="CsCheck" />
    <!--
      An independent MessagePack codec used ONLY as a conformance oracle for the MGPK serialization the CESR
      specification requires a parser to support. The library ships the serializer-agnostic decode seam plus the
      JSON, CBOR, and CESR-native arms; it does not bundle an MGPK reader. This test mints and decodes MGPK KERI
      event bytes with this codec and feeds the result through the same neutral-map reader, demonstrating that an
      MGPK deployment wires through the seam unchanged. Test-only, never referenced by any src/ project.
    -->
    <!--
      The NuGet audit advisories for this package concern untrusted-data deserialization (typeless/contractless
      paths and hash-collision denial of service). This test uses only the low-level reader and writer over bytes
      it mints itself, so that class does not apply; the audit warnings are suppressed for this reference alone,
      not project-wide, so real advisories on every other package still fail the build.
    -->
    <PackageReference Include="MessagePack" NoWarn="NU1902;NU1903" />
    <PackageReference Include="LiquidTestReports.Markdown" />
    <PackageReference Include="System.Security.Cryptography.ProtectedData" />
    <PackageReference Include="ModelContextProtocol" />
    <PackageReference Include="System.CommandLine" />
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" />
    <PackageReference Include="SimpleBase" />
    <PackageReference Include="System.Reactive" />
    <PackageReference Include="Microsoft.Reactive.Testing" />
    <PackageReference Include="Microsoft.IdentityModel.Tokens" />
    <PackageReference Update="Microsoft.Testing.Extensions.CodeCoverage">
      <VersionOverride>18.6.2</VersionOverride>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <!--
      Kestrel + HttpContext mapping types live in the Microsoft.AspNetCore.App
      shared framework rather than as NuGet packages on .NET 10. Test
      infrastructure (Kestrel host + IHttpApplication mapping) needs this
      reference; the library itself never does.
    -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Verifiable.Acdc\Verifiable.Acdc.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.Apdu\Verifiable.Apdu.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.BouncyCastle\Verifiable.BouncyCastle.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.Cbor\Verifiable.Cbor.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.Cesr\Verifiable.Cesr.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.Core\Verifiable.Core.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.Cryptography\Verifiable.Cryptography.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.DidComm\Verifiable.DidComm.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.DidWebs\Verifiable.DidWebs.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.Fido2\Verifiable.Fido2.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.Foundation\Verifiable.Foundation.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.JCose\Verifiable.JCose.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.Json\Verifiable.Json.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.Keri\Verifiable.Keri.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.Microsoft\Verifiable.Microsoft.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.NSec\Verifiable.NSec.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.OAuth\Verifiable.OAuth.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.Vcalm\Verifiable.Vcalm.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.WebFinger\Verifiable.WebFinger.csproj" />
    <ProjectReference Include="..\..\src\Verifiable.Tpm\Verifiable.Tpm.csproj" />
    <ProjectReference Include="..\..\src\Verifiable\Verifiable.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!--
      The protocol-neutral endpoint host lives in Verifiable.Server. Its
      dispatch model types (CapabilityIdentifier, ServerHttpResponse, FlowState,
      FlowInput, IncomingRequest, RequestFields, RequestHeaders, EndpointChain)
      are named across the whole OAuth test suite; a project-level using keeps
      the per-file using lists focused on the protocol families.
    -->
    <Using Include="Verifiable.Server" />
    <Using Include="Verifiable.Foundation" />
    <Using Include="Lumoin.Base" />
  </ItemGroup>

</Project>

